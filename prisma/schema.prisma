generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
  technician
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
  cng
}

enum Transmission {
  manual
  automatic
  semi_automatic
}

enum IssueType {
  mechanical_failure
  electrical_issue
  tire_related
  battery_issue
  engine_problem
  brake_issue
  other
}

enum ServiceLocationType {
  roadside
  home
  office
}

enum RequestStatus {
  created
  pending_offers
  offer_accepted
  in_progress
  completed
  cancelled
}

enum OfferStatus {
  pending
  accepted
  rejected
  expired
}

enum JobStatus {
  assigned
  in_progress
  completed
  verified
}

enum TechnicianType {
  individual
  garage
}

enum RepairMode {
  onsite
  tow_to_garage
}

enum MediaType {
  image
  video
  audio
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum InvoiceItemType {
  labor
  part
  towing
  diagnostic
  other
}

model User {
  user_id           String             @id @default(uuid()) @db.Uuid
  full_name         String
  email             String             @unique
  phone_number      String             @unique
  password          String
  role              Role
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  vehicles          UserVehicle[]
  serviceRequests   ServiceRequest[]
  sentMessages      PlatformMessage[]  @relation("sentMessages")
  receivedMessages  PlatformMessage[]  @relation("receivedMessages")
  reviews           Review[]
  technicianProfile TechnicianProfile?
  auditLogs         AuditLog[]
  deleted_at        DateTime?

  @@map("users")
}

model CarCompany {
  company_id         Int                    @id @default(autoincrement())
  company_name       String                 @unique
  models             CarModel[]
  technicianSupports TechnicianCarSupport[]

  @@map("car_companies")
}

model CarModel {
  model_id   Int          @id @default(autoincrement())
  company_id Int
  model_name String
  company    CarCompany   @relation(fields: [company_id], references: [company_id])
  variants   CarVariant[]

  @@map("car_models")
}

model CarVariant {
  variant_id           Int                    @id @default(autoincrement())
  model_id             Int
  variant_name         String
  year                 Int
  fuel_type            FuelType
  transmission         Transmission
  model                CarModel               @relation(fields: [model_id], references: [model_id])
  userVehicles         UserVehicle[]
  technicianCarSupport TechnicianCarSupport[]

  @@map("car_variants")
}

model CarPartCategory {
  category_id   Int       @id @default(autoincrement())
  category_name String    @unique
  parts         CarPart[]

  @@map("car_part_categories")
}

model CarPart {
  part_id              Int                   @id @default(autoincrement())
  part_name            String
  category_id          Int
  category             CarPartCategory       @relation(fields: [category_id], references: [category_id])
  prices               PartPrice[]
  serviceRequestParts  ServiceRequestPart[]
  technicianPartSkills TechnicianPartSkill[]

  @@map("car_parts")
}

model PartPrice {
  price_id   Int     @id @default(autoincrement())
  part_id    Int
  variant_id Int
  price      Decimal @db.Decimal(10, 2)
  part       CarPart @relation(fields: [part_id], references: [part_id])

  @@map("part_prices")
}

model UserVehicle {
  vehicle_id          String           @id @default(uuid()) @db.Uuid
  user_id             String           @db.Uuid
  variant_id          Int
  registration_number String           @unique
  vin_number          String           @unique
  user                User             @relation(fields: [user_id], references: [user_id])
  variant             CarVariant       @relation(fields: [variant_id], references: [variant_id])
  serviceRequests     ServiceRequest[]

  @@map("user_vehicles")
}

model ServiceRequest {
  request_id            String                @id @default(uuid()) @db.Uuid
  user_id               String                @db.Uuid
  vehicle_id            String                @db.Uuid
  issue_description     String
  issue_type            IssueType
  breakdown_latitude    Float?
  breakdown_longitude   Float?
  service_location_type ServiceLocationType
  requires_towing       Boolean               @default(false)
  status                RequestStatus         @default(created)
  created_at            DateTime              @default(now())
  deleted_at            DateTime?
  user                  User                  @relation(fields: [user_id], references: [user_id])
  vehicle               UserVehicle           @relation(fields: [vehicle_id], references: [vehicle_id])
  parts                 ServiceRequestPart[]
  media                 ServiceRequestMedia[]
  offers                TechnicianOffer[]
  job                   Job?
  messages              PlatformMessage[]

  @@index([status])
  @@index([breakdown_latitude, breakdown_longitude])
  @@map("service_requests")
}

model ServiceRequestPart {
  request_part_id String         @id @default(uuid()) @db.Uuid
  request_id      String         @db.Uuid
  part_id         Int
  quantity        Int
  request         ServiceRequest @relation(fields: [request_id], references: [request_id])
  part            CarPart        @relation(fields: [part_id], references: [part_id])

  @@map("service_request_parts")
}

model ServiceRequestMedia {
  media_id   String         @id @default(uuid()) @db.Uuid
  request_id String         @db.Uuid
  media_url  String
  media_type MediaType
  request    ServiceRequest @relation(fields: [request_id], references: [request_id])

  @@map("service_request_media")
}

model TechnicianProfile {
  technician_id   String                    @id @default(uuid()) @db.Uuid
  user_id         String                    @unique @db.Uuid
  business_name   String?
  technician_type TechnicianType
  location        String
  latitude        Float
  longitude       Float
  service_radius  Int
  rating          Decimal?                  @db.Decimal(3, 2)
  total_reviews   Int                       @default(0)
  is_verified     Boolean                   @default(false)
  is_online       Boolean                   @default(false)
  user            User                      @relation(fields: [user_id], references: [user_id])
  carSupports     TechnicianCarSupport[]
  partSkills      TechnicianPartSkill[]
  certifications  TechnicianCertification[]
  resources       TechnicianResource[]
  offers          TechnicianOffer[]
  jobs            Job[]

  @@index([latitude, longitude])
  @@map("technician_profiles")
}

model TechnicianCarSupport {
  support_id    String            @id @default(uuid()) @db.Uuid
  technician_id String            @db.Uuid
  company_id    Int
  variant_id    Int?
  technician    TechnicianProfile @relation(fields: [technician_id], references: [technician_id])
  company       CarCompany        @relation(fields: [company_id], references: [company_id])
  variant       CarVariant?       @relation(fields: [variant_id], references: [variant_id])

  @@map("technician_car_supports")
}

model TechnicianPartSkill {
  skill_id      String            @id @default(uuid()) @db.Uuid
  technician_id String            @db.Uuid
  part_id       Int
  technician    TechnicianProfile @relation(fields: [technician_id], references: [technician_id])
  part          CarPart           @relation(fields: [part_id], references: [part_id])

  @@map("technician_part_skills")
}

model TechnicianCertification {
  certification_id String            @id @default(uuid()) @db.Uuid
  technician_id    String            @db.Uuid
  certification    String
  issued_by        String
  issue_date       DateTime
  expiry_date      DateTime?
  technician       TechnicianProfile @relation(fields: [technician_id], references: [technician_id])

  @@map("technician_certifications")
}

model TechnicianResource {
  resource_id   String            @id @default(uuid()) @db.Uuid
  technician_id String            @db.Uuid
  resource_type String
  description   String
  technician    TechnicianProfile @relation(fields: [technician_id], references: [technician_id])

  @@map("technician_resources")
}

model TechnicianOffer {
  offer_id       String            @id @default(uuid()) @db.Uuid
  request_id     String            @db.Uuid
  technician_id  String            @db.Uuid
  repair_mode    RepairMode
  estimated_cost Decimal           @db.Decimal(10, 2)
  estimated_time Int
  message        String?
  status         OfferStatus       @default(pending)
  created_at     DateTime          @default(now())
  request        ServiceRequest    @relation(fields: [request_id], references: [request_id])
  technician     TechnicianProfile @relation(fields: [technician_id], references: [technician_id])
  job            Job?

  @@map("technician_offers")
}

model Job {
  job_id        String            @id @default(uuid()) @db.Uuid
  request_id    String            @unique @db.Uuid
  technician_id String            @db.Uuid
  offer_id      String            @unique @db.Uuid
  status        JobStatus
  started_at    DateTime?
  completed_at  DateTime?
  deleted_at    DateTime?
  request       ServiceRequest    @relation(fields: [request_id], references: [request_id])
  technician    TechnicianProfile @relation(fields: [technician_id], references: [technician_id])
  offer         TechnicianOffer   @relation(fields: [offer_id], references: [offer_id])
  invoice       Invoice?

  @@index([status])
  @@map("jobs")
}

model PlatformMessage {
  message_id  String         @id @default(uuid()) @db.Uuid
  request_id  String         @db.Uuid
  sender_id   String         @db.Uuid
  receiver_id String         @db.Uuid
  message     String
  sent_at     DateTime       @default(now())
  is_read     Boolean        @default(false)
  request     ServiceRequest @relation(fields: [request_id], references: [request_id])
  sender      User           @relation("sentMessages", fields: [sender_id], references: [user_id])
  receiver    User           @relation("receivedMessages", fields: [receiver_id], references: [user_id])

  @@map("platform_messages")
}

model Invoice {
  invoice_id       String        @id @default(uuid()) @db.Uuid
  job_id           String        @unique @db.Uuid
  subtotal         Decimal       @db.Decimal(10, 2)
  tax              Decimal       @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  payment_status   PaymentStatus
  transaction_id   String?       @unique
  payment_method   String?
  gateway_response Json?
  issued_at        DateTime      @default(now())
  paid_at          DateTime?
  deleted_at       DateTime?
  job              Job           @relation(fields: [job_id], references: [job_id])
  items            InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  item_id     String          @id @default(uuid()) @db.Uuid
  invoice_id  String          @db.Uuid
  item_type   InvoiceItemType
  description String
  quantity    Int
  unit_price  Decimal         @db.Decimal(10, 2)
  total_price Decimal         @db.Decimal(10, 2)
  invoice     Invoice         @relation(fields: [invoice_id], references: [invoice_id])

  @@map("invoice_items")
}

model Review {
  review_id  String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [user_id])

  @@map("reviews")
}

model AuditLog {
  log_id       String   @id @default(uuid()) @db.Uuid
  entity_type  String
  entity_id    String
  action       String
  old_value    Json?
  new_value    Json?
  performed_by String   @db.Uuid
  created_at   DateTime @default(now())
  user         User     @relation(fields: [performed_by], references: [user_id])

  @@map("audit_logs")
}
